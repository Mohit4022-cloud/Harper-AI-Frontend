# Database
DATABASE_URL="postgresql://user:password@localhost:5432/harper_ai"
DIRECT_URL="postgresql://user:password@localhost:5432/harper_ai"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# Service Worker (set to 'true' to enable in development)
NEXT_PUBLIC_ENABLE_SERVICE_WORKER="false"

# Analytics (optional)
ANALYTICS_ENDPOINT=""
ANALYTICS_API_KEY=""

# Slack Webhooks (optional)
SLACK_WEBHOOK_URL=""

# Image Domains (comma-separated)
NEXT_PUBLIC_IMAGE_DOMAINS="cdn.harperai.com,avatars.harperai.com"

# Redis (optional, for rate limiting in production)
REDIS_URL=""

# Sentry (optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""

# Environment
NODE_ENV="development"