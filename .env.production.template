# Production Environment Variables Template
# Copy this to .env.production and fill in the values

# Database (Required)
DATABASE_URL="postgresql://user:password@host:5432/database_name"
DIRECT_URL="postgresql://user:password@host:5432/database_name"

# NextAuth (Required)
NEXTAUTH_URL="https://app.harperai.com"
NEXTAUTH_SECRET="generate-with-openssl-rand-base64-32"

# API Configuration
NEXT_PUBLIC_API_URL=https://api.harperai.com
NEXT_PUBLIC_WS_URL=wss://ws.harperai.com
NEXT_PUBLIC_APP_URL=https://app.harperai.com

# Feature Flags
NEXT_PUBLIC_ENABLE_PPR=true
NEXT_PUBLIC_ENABLE_REACT_COMPILER=true
NEXT_PUBLIC_ENABLE_SERVICE_WORKER=true
NEXT_PUBLIC_ENABLE_PERFORMANCE_MONITORING=true

# Analytics & Monitoring (Optional but recommended)
NEXT_PUBLIC_ANALYTICS_ID=your-analytics-id
SENTRY_DSN=your-server-sentry-dsn
NEXT_PUBLIC_SENTRY_DSN=your-client-sentry-dsn
NEXT_PUBLIC_HOTJAR_ID=your-hotjar-id

# Performance
NEXT_PUBLIC_IMAGE_DOMAINS=cdn.harperai.com,avatars.harperai.com
NEXT_PUBLIC_CDN_URL=https://cdn.harperai.com

# WebSocket Configuration
NEXT_PUBLIC_WS_RECONNECT_ATTEMPTS=5
NEXT_PUBLIC_WS_RECONNECT_DELAY=1000

# Real-time Features
NEXT_PUBLIC_REALTIME_SYNC_INTERVAL=5000
NEXT_PUBLIC_OFFLINE_SYNC_ENABLED=true

# UI Configuration
NEXT_PUBLIC_VIRTUAL_TABLE_OVERSCAN=20
NEXT_PUBLIC_ANIMATION_REDUCED_MOTION=false

# Redis (Optional - for rate limiting)
REDIS_URL=""

# Slack Webhooks (Optional)
SLACK_WEBHOOK_URL=""

# Environment
NODE_ENV="production"